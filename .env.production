# Configuration pour environnement de production
# Copier ce fichier en .env et remplir les valeurs manquantes

# === Configuration de base ===
PORT=7331
NODE_ENV=production
SELF_HOSTED_MODE=false
DISABLE_SIGNUP=false  # Mettre à true si vous ne voulez pas de nouveaux utilisateurs

# === Base de données ===
# IMPORTANT: Utiliser une base de données PostgreSQL sécurisée
# Format: postgresql://user:password@host:port/database
# Pour production avec Docker, utiliser un service PostgreSQL séparé
DATABASE_URL="postgresql://user:secure_password@postgres:5432/taxhacker"

# === Uploads ===
UPLOAD_PATH="/app/data/uploads"

# === Certificats SSL/TLS ===
# Pour production, utiliser Let's Encrypt ou un certificat valide
BASE_URL="https://votre-domaine.com"

# === Modèles IA - Au moins un doit être configuré ===
# OpenAI
OPENAI_MODEL_NAME="gpt-4o-mini"
OPENAI_API_KEY="sk-..."  # Clé API OpenAI

# Google Gemini
GOOGLE_MODEL_NAME="gemini-2.5-flash"
GOOGLE_API_KEY=""  # Clé API Google

# Mistral
MISTRAL_MODEL_NAME="mistral-medium-latest"
MISTRAL_API_KEY=""  # Clé API Mistral

# === Authentification ===
# IMPORTANT: Générer une clé secrète aléatoire très sécurisée (minimum 32 caractères)
BETTER_AUTH_SECRET="votre-clé-secrète-aléatoire-très-longue-et-sécurisée-ici"

# === Stripe (Optionnel - pour les paiements) ===
# Laisser vide si les paiements ne sont pas nécessaires
STRIPE_SECRET_KEY="sk_live_..."  # Clé secrète Stripe (production)
STRIPE_WEBHOOK_SECRET="whsec_..."  # Secret Webhook Stripe

# === Email - Resend (Optionnel) ===
# pour l'envoi d'emails (notifications, réinitialisation mot de passe, etc.)
RESEND_API_KEY="re_..."  # Clé API Resend
RESEND_AUDIENCE_ID="aud_..."  # ID audience Resend
RESEND_FROM_EMAIL="TaxHacker <noreply@votre-domaine.com>"

# === Sentry (Optionnel - pour le monitoring des erreurs) ===
# Configuration error monitoring en production
NEXT_PUBLIC_SENTRY_DSN=""  # DSN public Sentry
SENTRY_ORG="votre-org"  # Organisation Sentry
SENTRY_PROJECT="votre-project"  # Projet Sentry
SENTRY_AUTH_TOKEN=""  # Token d'authentification Sentry

# === Docker Registry (Optionnel) ===
# Pour utiliser un registre Docker personnalisé au lieu de la build locale
# DOCKER_REGISTRY="registry.example.com/taxhacker"
# DOCKER_TAG="latest"
